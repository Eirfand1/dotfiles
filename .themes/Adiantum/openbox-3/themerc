colorscheme: rosepine dawn

!! Menu
menu.border.width: 8
menu.border.color: #e3e3df
menu.overlap.x: -6
menu.title.bg: flat
menu.title.bg.color: #e3e3df
menu.title.text.color: #817774
menu.title.text.justify: center
menu.items.bg: flat
menu.items.bg.color: #e3e3df
menu.items.text.color: #817774
menu.items.active.bg: flat
menu.items.active.bg.color: #8fa98f
menu.items.active.text.color: #495e60
menu.items.disabled.text.color: #3f414d
menu.items.justify: left
menu.separator.padding.height: 2
menu.separator.color: #e3e3df

!! Titlebar
window.*.title.bg: flat
window.*.label.bg: parentrelative
window.active.title.bg.color: #d9d9d4
window.active.label.text.color: #817774
window.inactive.title.bg.color: #d9d9d4
window.inactive.label.text.color: #928f90
window.label.text.justify: center

!! Titlebar buttons
window.*.button.*.bg: parentrelative
window.*.button.*.pressed.bg: flat
window.active.button.*.image.color: #817774
window.active.button.*.hover.image.color: #8fa98f
window.active.button.*.pressed.bg.color: #8fa98f
window.active.button.disabled.image.color: #c6c4c5
window.inactive.button.*.image.color: #c6c4c5
window.inactive.button.disabled.image.color: #c6c4c5

!! Borders
border.width: 0
padding.width: 6 
padding.height: 4
window.client.padding.width: 0
window.client.padding.height: 0
window.handle.width: 2
window.active.border.color: #d9d9d4
window.active.client.color:  #d9d9d4
window.active.handle.bg: flat
window.active.handle.bg.color: #d9d9d4
window.active.grip.bg: flat
window.active.grip.bg.color: #d9d9d4
window.inactive.grip.bg: flat
window.inactive.grip.bg.color: #d9d9d4
window.inactive.border.color: #d9d9d4
window.inactive.handle.bg: flat
window.inactive.handle.bg.color: #d9d9d4
window.inactive.client.color: #d9d9d4

!! OSD
osd.border.width: 1
osd.border.color: #d9d9d4
osd.label.text.color: #4e525d
osd.bg: flat
osd.bg.color: #d9d9d4
osd.label.bg: flat
osd.label.bg.color: #d9d9d4
osd.hilight.bg: flat
osd.hilight.bg.color: #8fa98f
osd.unhilight.bg: flat solid
osd.unhilight.bg.color: #c6c4c5
